{
  "name": "opencode-regolo",
  "version": "1.0.2",
  "description": "OpenCode plugin for Regolo AI — adds regolo.ai as a provider with API key setup, model registration, and oh-my-openagent integration",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "tsc"
  },
  "keywords": [
    "opencode",
    "plugin",
    "regolo",
    "regolo-ai",
    "ai",
    "llm",
    "provider"
  ],
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/regolo-ai/opencode-regolo.git"
  },
  "homepage": "https://github.com/regolo-ai/opencode-regolo#readme",
  "peerDependencies": {},
  "devDependencies": {
    "@types/node": "^22.19.17",
    "typescript": "^5.7.0"
  },
  "peerDependenciesMeta": {
    "opencode": {
      "optional": true
    }
  }
}
